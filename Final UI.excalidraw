      "isDeleted": false,
      "boundElements": null,
      "updated": 1774868185790,
      "link": null,
      "locked": false,
      "text": "Notes:\n\n1. Project API's can expire\n2. We can add Multiple keys for Langsmith - Fuse\n3. Changing the Key must not have any effect\n4. Store locally after a fixed Duration.\n5. Every Minutes Check for Risk (Not in Priority for now)\n6. Every 24 Hours Store the Data Locally.",
      "fontSize": 49.461455147416295,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Notes:\n\n1. Project API's can expire\n2. We can add Multiple keys for Langsmith - Fuse\n3. Changing the Key must not have any effect\n4. Store locally after a fixed Duration.\n5. Every Minutes Check for Risk (Not in Priority for now)\n6. Every 24 Hours Store the Data Locally.",
      "autoResize": true,
      "lineHeight": 1.25
    },
